# ✅ Node dependencies
node_modules/

# ✅ Expo local folders
.expo/
.expo-shared/
dist/
web-build/
expo-env.d.ts

# ✅ Native build output folders (safe to ignore)
android/.gradle/
android/app/build/
android/build/

ios/Pods/
ios/build/

# ✅ Metro bundler cache
.metro-cache/
metro-cache/
metro-health-check*

# ✅ Debug logs
npm-debug.*
yarn-debug.*
yarn-error.*
pnpm-debug.*

# ✅ Certificates & keys (never push these!)
*.jks
*.keystore
*.p8
*.p12
*.key
*.mobileprovision
*.pem

# ✅ Environment files (API keys, secrets, etc.)
.env
.env.*
.env*.local
firebase-service-account.json

# ✅ macOS & Windows junk files
.DS_Store
Thumbs.db

# ✅ Git merge conflict files
*.orig.*

# ✅ TypeScript
*.tsbuildinfo

# ✅ VSCode settings (optional but useful to ignore)
.vscode/

# ✅ Android local config
android/local.properties
