{
  "cli": {
    "version": ">= 3.15.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk",
        "ndk": "27.0.12077973"
      },
      "env": {
        "EXPO_USE_UPDATES": "false"
      }
    },
    "preview-apk": {
      "distribution": "internal",
      "channel": "preview-apk",
      "android": {
        "buildType": "apk",
        "ndk": "27.0.12077973"
      },
      "env": {
        "EXPO_USE_UPDATES": "true"
      }
    },
    "production": {
      "channel": "production",
      "android": {
        "buildType": "app-bundle",
        "ndk": "27.0.12077973"
      },
      "autoIncrement": true,
      "env": {
        "EXPO_USE_UPDATES": "true"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
